{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "paths": {
      "@/*": ["../../src/*"],
      "server-only": ["./shims/server-only"]
    }
  },
  "include": ["./**/*.ts"]
}
