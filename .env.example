# Local development environment
# Copy this file to .env and fill in the values.

# PostgreSQL connection string
# Matches the db service in docker-compose.yml
DATABASE_URL=postgresql://stamporama:stamporama@localhost:5432/stamporama

# Better Auth secret — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Base URL of the application (used by Better Auth for redirects)
BETTER_AUTH_URL=http://localhost:3000

# App version shown in the UI — set automatically by Docker build; leave empty for local dev
STAMPORAMA_VERSION=

# Directory for uploaded photo bytes (#112). Defaults to ./.data locally (gitignored) and
# /data in the container; only set this to override.
# STAMPORAMA_DATA_DIR=
# Hours a staged (dropped-but-unsaved) photo upload survives before the orphan-GC sweep.
# STAMPORAMA_PHOTO_UPLOAD_TTL_HOURS=3

# Active write backend for new photos (#138): `filesystem` (default) or `gcs`. Existing photos
# always keep serving from the backend they were written to, regardless of this setting.
# STAMPORAMA_STORAGE_BACKEND=filesystem
# --- Google Cloud Storage (only when STAMPORAMA_STORAGE_BACKEND=gcs) ---
# STAMPORAMA_GCS_BUCKET=my-stamporama-photos
# Optional object-key prefix inside the bucket.
# STAMPORAMA_GCS_KEY_PREFIX=
# Lifetime of the signed read URLs the app mints, in seconds (default 300).
# STAMPORAMA_GCS_SIGNED_URL_TTL_SECONDS=300
# Credentials via Application Default Credentials — path to a service-account key (also signs URLs).
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
