# Self-hosted production environment — managed by scripts/install.sh.
# Re-run the installer to reconfigure; it preserves keys you do not change.

# --- Compose ---
# Set by the installer based on your network choice.
COMPOSE_FILE=docker-compose.prod.yml
# Enable Watchtower auto-updates:
# COMPOSE_PROFILES=autoupdate

# --- Database ---
# External PostgreSQL connection string — provided by the operator.
DATABASE_URL=postgresql://user:password@host:5432/stamporama

# --- Auth ---
BETTER_AUTH_SECRET=change_me
BETTER_AUTH_URL=https://stamps.example.com

# --- Network ---
# Host port the app listens on
STAMPORAMA_HTTP_PORT=3000
# Shared Docker network name (only used when docker-compose.network.yml is active)
STAMPORAMA_DB_NETWORK=stamporama

# --- Photo storage (#112) ---
# Directory inside the container where uploaded photo bytes are written. Backed by the
# `stamporama-data` Docker volume in docker-compose.prod.yml. Leave as the default unless
# you also change the volume mount. Back this volume up alongside your database.
STAMPORAMA_DATA_DIR=/data
# Hours a staged (dropped-but-unsaved) upload survives before the orphan-GC sweep removes it.
# STAMPORAMA_PHOTO_UPLOAD_TTL_HOURS=3
#
# Active write backend for NEW photos (#138): `filesystem` (default) or `gcs`. Existing photos
# always keep serving from the backend they were written to, so switching is safe at any time.
# STAMPORAMA_STORAGE_BACKEND=filesystem
#
# --- Google Cloud Storage (only when STAMPORAMA_STORAGE_BACKEND=gcs) ---
# The installer (scripts/install.sh) can set all of this up for you — it asks for the bucket and
# key path, writes these keys, and generates docker-compose.gcs.yml to mount the key. To do it by
# hand instead: set the keys below and mount the service-account key file into the container
# (uncomment the volume in docker-compose.prod.yml, or add your own overlay to COMPOSE_FILE).
# Photos are served via short-lived signed URLs so bytes bypass the app; the same key signs them.
# STAMPORAMA_GCS_BUCKET=my-stamporama-photos
# STAMPORAMA_GCS_KEY_PREFIX=
# STAMPORAMA_GCS_SIGNED_URL_TTL_SECONDS=300
# GOOGLE_APPLICATION_CREDENTIALS=/secrets/gcs-key.json
# Host path to the key, remembered by the installer to regenerate the mount (unused by the app):
# STAMPORAMA_GCS_KEY_HOST_PATH=
#
# Move existing filesystem photos into the bucket so the stamporama-data volume can be retired:
#   docker compose exec app pnpm photos:migrate:gcs --delete-source

# --- Image ---
TAG=latest

# --- Auto-update ---
STAMPORAMA_UPDATE_INTERVAL=3600
STAMPORAMA_DOCKER_API_VERSION=1.44
