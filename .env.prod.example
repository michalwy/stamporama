# Self-hosted production environment
# Copy this file to .env and fill in all values before starting the stack.

# --- Compose file list ---
# Controls which compose files docker compose reads.
# For production with prebuilt image (default):
COMPOSE_FILE=docker-compose.yml:docker-compose.prod.yml
# For production with Watchtower auto-update:
# COMPOSE_FILE=docker-compose.yml:docker-compose.prod.yml

# --- Database ---
# PostgreSQL password — choose a strong random value
POSTGRES_PASSWORD=change_me

# Full connection string used by the app
DATABASE_URL=postgresql://stamporama:change_me@db:5432/stamporama

# --- Auth ---
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=change_me

# Public URL of the application (no trailing slash)
BETTER_AUTH_URL=https://stamps.example.com

# --- Image ---
# Docker image tag to run — set to a specific release (e.g. 0.2.0) for pinned deploys
TAG=latest

# --- App ---
# Baked into the image at build time; leave empty to use the image's built-in version
STAMPORAMA_VERSION=
