# Self-hosted production environment — managed by scripts/install.sh.
# Re-run the installer to reconfigure; it preserves keys you do not change.

# --- Compose ---
# Set by the installer based on your network choice.
COMPOSE_FILE=docker-compose.prod.yml
# Enable Watchtower auto-updates:
# COMPOSE_PROFILES=autoupdate

# --- Database ---
# External PostgreSQL connection string — provided by the operator.
DATABASE_URL=postgresql://user:password@host:5432/stamporama

# --- Auth ---
BETTER_AUTH_SECRET=change_me
BETTER_AUTH_URL=https://stamps.example.com

# --- Network ---
# Host port the app listens on
STAMPORAMA_HTTP_PORT=3000
# Shared Docker network name (only used when docker-compose.network.yml is active)
STAMPORAMA_DB_NETWORK=stamporama

# --- Image ---
TAG=latest

# --- Auto-update ---
STAMPORAMA_UPDATE_INTERVAL=3600
STAMPORAMA_DOCKER_API_VERSION=1.44
