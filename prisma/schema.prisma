generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String       @id
  name          String
  email         String       @unique
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime
  sessions      Session[]
  accounts      Account[]
  collections   Collection[]

  @@map("user")
}

model Collection {
  id        String   @id @default(cuid())
  slug      String
  name      String
  ownerId   String
  createdAt DateTime @default(now())

  owner           User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  collectionAreas CollectionArea[]
  catalogVendors  CatalogVendor[]

  @@unique([ownerId, slug])
  @@map("collection")
}

model CatalogVendor {
  id           String @id @default(cuid())
  collectionId String
  name         String
  abbreviation String

  collection    Collection    @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  catalogNames  CatalogName[]

  @@map("catalog_vendor")
}

model CatalogName {
  id           String  @id @default(cuid())
  vendorId     String
  name         String
  currency     String
  abbreviation String?

  vendor          CatalogVendor    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  catalogEditions CatalogEdition[]

  @@map("catalog_name")
}

model CatalogEdition {
  id            String @id @default(cuid())
  catalogNameId String
  year          Int

  catalogName CatalogName @relation(fields: [catalogNameId], references: [id], onDelete: Cascade)

  @@map("catalog_edition")
}

model CollectionArea {
  id           String   @id @default(cuid())
  collectionId String
  name         String
  parentId     String?
  description  String?
  catalogId    String?
  createdAt    DateTime @default(now())

  collection       Collection           @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  parent           CollectionArea?      @relation("CollectionAreaChildren", fields: [parentId], references: [id])
  children         CollectionArea[]     @relation("CollectionAreaChildren")
  stampAreaLinks   StampCollectionArea[]

  @@map("collection_area")
}

model StampCollectionArea {
  stampId           String
  collectionAreaId  String
  isPrimary         Boolean @default(false)

  collectionArea CollectionArea @relation(fields: [collectionAreaId], references: [id], onDelete: Cascade)

  @@id([stampId, collectionAreaId])
  @@map("stamp_collection_area")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}
