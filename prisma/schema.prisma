generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String       @id
  name          String
  email         String       @unique
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime
  sessions      Session[]
  accounts      Account[]
  collections   Collection[]

  @@map("user")
}

model Collection {
  id           String   @id @default(cuid())
  slug         String
  name         String
  baseCurrency String
  // Duplicate catalog-number policy (#85): "warn" (default) shows a non-blocking
  // warning; "block" prevents saving a stamp whose catalog identity (vendor +
  // effective area prefix + number) already exists in the collection.
  duplicateCatalogMode String @default("warn")
  ownerId      String
  createdAt    DateTime @default(now())

  owner           User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  collectionAreas CollectionArea[]
  catalogVendors  CatalogVendor[]
  stamps          Stamp[]
  issues          Issue[]
  exchangeRates   ExchangeRate[]
  stampConditions StampCondition[]
  certificateStatuses CertificateStatus[]
  stampSubtypes   StampSubtype[]
  items           Item[]
  contacts        Contact[]
  locations       Location[]
  purchases       Purchase[]
  offers          Offer[]
  sales           Sale[]

  @@unique([ownerId, slug])
  @@map("collection")
}

model StampCondition {
  id           String @id @default(cuid())
  collectionId String
  name         String
  abbreviation String
  sortOrder    Int

  collection    Collection          @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  catalogPrices StampCatalogPrice[]
  items         Item[]

  @@index([collectionId])
  @@map("stamp_condition")
}

model CertificateStatus {
  id           String @id @default(cuid())
  collectionId String
  name         String
  abbreviation String
  sortOrder    Int

  collection    Collection          @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  catalogPrices StampCatalogPrice[]
  items         Item[]

  @@index([collectionId])
  @@map("certificate_status")
}

model StampSubtype {
  id            String  @id @default(cuid())
  collectionId  String
  name          String
  actsAsVariant Boolean @default(true)
  isDefault     Boolean @default(false)
  sortOrder     Int

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  stamps     Stamp[]

  @@index([collectionId])
  // Exactly-one-default is enforced by a partial unique index written by hand in
  // the migration SQL (Prisma cannot express partial indexes):
  //   CREATE UNIQUE INDEX "stamp_subtype_one_default"
  //     ON "stamp_subtype"("collectionId") WHERE "isDefault";
  @@map("stamp_subtype")
}

model CatalogVendor {
  id           String @id @default(cuid())
  collectionId String
  name         String
  abbreviation String

  collection            Collection             @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  catalogNames          CatalogName[]
  stampCatalogNumbers   StampCatalogNumber[]
  issueCatalogNumbers   IssueCatalogNumber[]
  collectionAreaVendors CollectionAreaVendor[]

  @@map("catalog_vendor")
}

model CatalogName {
  id       String @id @default(cuid())
  vendorId String
  name     String
  currency String

  vendor                 CatalogVendor          @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  catalogEditions        CatalogEdition[]
  collectionAreaCatalogs CollectionAreaCatalog[]
  primaryForAreas        CollectionArea[]        @relation("CollectionAreaPrimaryCatalog")

  @@map("catalog_name")
}

model CatalogEdition {
  id            String @id @default(cuid())
  catalogNameId String
  year          Int

  catalogName        CatalogName          @relation(fields: [catalogNameId], references: [id], onDelete: Cascade)
  stampCatalogPrices StampCatalogPrice[]

  @@map("catalog_edition")
}

model CollectionArea {
  id                   String   @id @default(cuid())
  collectionId         String
  name                 String
  parentId             String?
  description          String?
  catalogId            String?
  primaryCatalogNameId String?
  createdAt            DateTime @default(now())

  collection             Collection             @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  parent                 CollectionArea?        @relation("CollectionAreaChildren", fields: [parentId], references: [id])
  children               CollectionArea[]       @relation("CollectionAreaChildren")
  stampAreaLinks         StampCollectionArea[]
  primaryCatalogName     CatalogName?           @relation("CollectionAreaPrimaryCatalog", fields: [primaryCatalogNameId], references: [id])
  collectionAreaCatalogs CollectionAreaCatalog[]
  collectionAreaVendors  CollectionAreaVendor[]
  issues                 Issue[]

  @@map("collection_area")
}

model StampCollectionArea {
  stampId          String
  collectionAreaId String
  isPrimary        Boolean @default(false)

  stamp          Stamp          @relation(fields: [stampId], references: [id], onDelete: Cascade)
  collectionArea CollectionArea @relation(fields: [collectionAreaId], references: [id], onDelete: Cascade)

  @@id([stampId, collectionAreaId])
  @@map("stamp_collection_area")
}

model Stamp {
  id           String   @id @default(cuid())
  collectionId String
  parentId     String?
  subtypeId    String?
  // Per-stamp override of the subtype's `actsAsVariant` (ADR-0010). Tri-state:
  // null = inherit from the subtype; true/false = force. Effective value is
  // `actsAsVariantOverride ?? subtype.actsAsVariant`. Meaningful only for children.
  actsAsVariantOverride Boolean?
  name         String?
  issuedDay    Int?
  issuedMonth  Int?
  issuedYear   Int?
  createdAt    DateTime @default(now())

  collection        Collection            @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  parent            Stamp?                @relation("StampVariants", fields: [parentId], references: [id])
  subtype           StampSubtype?         @relation(fields: [subtypeId], references: [id], onDelete: Restrict)
  variants          Stamp[]               @relation("StampVariants")
  stampAreaLinks    StampCollectionArea[]
  catalogNumbers    StampCatalogNumber[]
  catalogPrices     StampCatalogPrice[]
  issueMemberships  IssueMember[]         @relation("IssueMemberStamp")
  items              Item[]               @relation("ItemStamp")
  variantHistoryFrom ItemVariantHistory[] @relation("ItemVariantHistoryFrom")
  variantHistoryTo   ItemVariantHistory[] @relation("ItemVariantHistoryTo")
  photos             Photo[]

  @@index([subtypeId])
  @@map("stamp")
}

model StampCatalogNumber {
  stampId         String
  catalogVendorId String
  number          String

  stamp         Stamp         @relation(fields: [stampId], references: [id], onDelete: Cascade)
  catalogVendor CatalogVendor @relation(fields: [catalogVendorId], references: [id], onDelete: Cascade)

  @@id([stampId, catalogVendorId])
  @@map("stamp_catalog_number")
}

model StampCatalogPrice {
  id                  String  @id @default(cuid())
  stampId             String
  catalogEditionId    String
  conditionId         String
  certificateStatusId String?
  price               Decimal @db.Decimal(10, 2)
  currency            String

  stamp             Stamp              @relation(fields: [stampId], references: [id], onDelete: Cascade)
  catalogEdition    CatalogEdition     @relation(fields: [catalogEditionId], references: [id], onDelete: Cascade)
  condition         StampCondition     @relation(fields: [conditionId], references: [id], onDelete: Restrict)
  certificateStatus CertificateStatus? @relation(fields: [certificateStatusId], references: [id], onDelete: Restrict)

  // Uniqueness on (stampId, catalogEditionId, conditionId, certificateStatusId)
  // is enforced by a raw `UNIQUE ... NULLS NOT DISTINCT` index (see migration),
  // which Prisma cannot express — so no @@unique here. Requires PostgreSQL 15+.
  @@index([stampId])
  @@index([catalogEditionId])
  @@index([conditionId])
  @@index([certificateStatusId])
  @@map("stamp_catalog_price")
}

model Item {
  id                  String   @id @default(cuid())
  collectionId        String
  stampId             String
  conditionId         String
  certificateStatusId String?
  inCollection        Boolean  @default(true)
  forSale             Boolean  @default(false)
  forTrade            Boolean  @default(false)
  // Acquisition link (ADR-0009). A purchase is one channel among several; `lotId` is a
  // nullable FK to a `PurchaseLot` (`onDelete: Restrict`). Supplier/date/price now live
  // on `Purchase`/`PurchaseLot`, superseding the flat cost fields from ADR-0007.
  lotId               String?
  // Physical delivery axis (ADR-0009 §5), orthogonal to `inCollection`/`forSale`/`forTrade`.
  // One of: ordered | in_transit | delivered | not_delivered | damaged. Defaults `delivered`
  // — a manually added copy is in hand; purchase intake sets `ordered` explicitly (and leaves
  // the copy out of the collection until it arrives).
  deliveryState       String   @default("delivered")
  // Base-currency cost-basis snapshot (ADR-0009 §2/§3). Null = pending (lot still open,
  // or the copy entered via a channel that has not written a cost yet).
  costBasis           Decimal? @db.Decimal(10, 2)
  notes               String?
  // Physical storage: at most one assignable `Location` per copy, plus an optional
  // free-text identifier within that location (e.g. a page/pocket ref like `A234`),
  // not unique. `onDelete: Restrict` guards against orphaning a stored copy (#56).
  locationId          String?
  locationRef         String?
  createdAt           DateTime @default(now())

  collection        Collection           @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  stamp             Stamp                @relation("ItemStamp", fields: [stampId], references: [id], onDelete: Cascade)
  condition         StampCondition       @relation(fields: [conditionId], references: [id], onDelete: Restrict)
  certificateStatus CertificateStatus?   @relation(fields: [certificateStatusId], references: [id], onDelete: Restrict)
  lot               PurchaseLot?         @relation(fields: [lotId], references: [id], onDelete: Restrict)
  location          Location?            @relation(fields: [locationId], references: [id], onDelete: Restrict)
  variantHistory    ItemVariantHistory[]
  photos            Photo[]
  // Sales module (ADR-0013). A copy is packaged into offer sets (N:M — the same copy can be
  // listed on several platforms at once) and, once sold, is recorded on exactly one `SaleLine`
  // via the `sale_line_item` join (the DB-level no-double-sale guard is the unique on `itemId`).
  offerSetMemberships OfferSetItem[]
  saleLineItems       SaleLineItem[]

  @@index([collectionId])
  @@index([stampId])
  @@index([conditionId])
  @@index([lotId])
  @@index([locationId])
  @@map("item")
}

// A photo attached to an inventory copy (#112). One `Item` has many `Photo`s.
// `role` reserves two singleton slots — `front` / `back` — each holding at most one image
// (enforced by the partial-null unique on `[itemId, role]`; multiple NULLs stay distinct in
// Postgres, so titled extras are unlimited). Extras (role = null) carry a free-text `title`
// and are drag-orderable via `sortOrder`; front/back are fixed slots outside the ordering.
//
// `storageBackend` records which storage binding holds this photo's bytes. Only `filesystem`
// exists today (defaulted); it is the per-photo read seam that lets #138 add GCS with no forced
// migration (write-one-read-many). Bytes live at `<collectionId>/<photoId>/{full,thumb}.<ext>`
// via the storage interface (ADR-0011) — Prisma cascade removes this row but the domain must
// delete the stored bytes explicitly (no orphaned files).
//
// **Polymorphic owner** (#137): exactly one of `itemId` / `stampId` is set (raw CHECK in the
// migration). A copy photo documents a specific owned piece; a stamp photo is a
// representative/reference image of the catalog stamp or variant. Front/back are singleton
// slots *per owner*, enforced by two raw *partial* unique `(*, role)` indexes — a plain unique
// on the nullable `itemId` would let every stamp photo collide on `(NULL, 'front')`. NULL role
// (titled extras) stays unlimited. A copy photo promoted to its stamp is an independent row
// with its own duplicated bytes and lifecycle.
model Photo {
  id             String   @id @default(cuid())
  itemId         String?
  stampId        String?
  role           String?
  title          String?
  storageBackend String   @default("filesystem")
  storageKey     String
  mime           String
  width          Int
  height         Int
  sizeBytes      Int
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())

  item  Item?  @relation(fields: [itemId], references: [id], onDelete: Cascade)
  stamp Stamp? @relation(fields: [stampId], references: [id], onDelete: Cascade)

  // Owner XOR (CHECK) and the two per-owner partial unique `(*, role)` indexes are declared
  // in the migration SQL — Prisma cannot express partial unique indexes or check constraints.
  @@index([itemId])
  @@index([stampId])
  @@map("photo")
}

// Staging row for an eager, pre-Save photo upload (#112). On drop, the file is processed by
// `sharp` and its `full` + `thumb` bytes are written to the active storage backend under a
// staging key *before* any `Photo` row exists; this row records the pending bytes. On Save,
// the dialog's change-set promotes selected uploads into `Photo` rows (bytes moved to the
// permanent key). On Cancel, rows are simply left unreferenced. An hourly orphan-GC sweep
// (instrumentation `register()`) deletes rows older than a TTL plus their bytes — the only
// cleanup path for abandoned drops. Owner-agnostic, so #137 reuses it for stamp uploads.
model PhotoUpload {
  id             String   @id @default(cuid())
  collectionId   String
  storageBackend String   @default("filesystem")
  storageKey     String
  mime           String
  width          Int
  height         Int
  sizeBytes      Int
  createdAt      DateTime @default(now())

  @@index([createdAt])
  @@map("photo_upload")
}

model ItemVariantHistory {
  id          String   @id @default(cuid())
  itemId      String
  fromStampId String
  toStampId   String
  changedAt   DateTime @default(now())
  note        String?

  item      Item  @relation(fields: [itemId], references: [id], onDelete: Cascade)
  fromStamp Stamp @relation("ItemVariantHistoryFrom", fields: [fromStampId], references: [id], onDelete: Cascade)
  toStamp   Stamp @relation("ItemVariantHistoryTo", fields: [toStampId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@map("item_variant_history")
}

// Purchase transaction header (ADR-0009 §1). A single acquisition event: optional
// supplier, one transaction currency, shared shipping cost, and a physical delivery
// status. Its inventory lines are `PurchaseLot`s; non-inventory lines are
// `PurchaseExpense`s. Scoped to a collection.
model Purchase {
  id           String   @id @default(cuid())
  collectionId String
  // Optional supplier — who the stamps were bought from. `onDelete: Restrict`: a contact
  // referenced by a purchase cannot be deleted without first detaching it (ADR-0008 §4,
  // ADR-0009).
  contactId    String?
  // Optional platform — the marketplace/intermediary a purchase went through (e.g. Allegro,
  // eBay), distinct from the supplier (ADR-0009 §1). A `Contact` carrying the `platform`
  // role; same `onDelete: Restrict` guard.
  platformId   String?
  // The moment money was spent; the FX rate is frozen as of this date.
  purchasedAt  DateTime @db.Date
  // Single transaction currency for every amount on this purchase and its lines.
  currency     String
  // Base-currency FX rate frozen at `purchasedAt` (ADR-0009 §4), reusing the
  // `ExchangeRate` mechanism (#20). Extra fractional digits like `ExchangeRate.rate`
  // (DECIMAL(65,30)); null when base == transaction currency or no rate is known yet.
  fxRateToBase Decimal?
  // Shared cost (shipping/handling) distributed across all lines by price (ADR-0009 §3).
  shippingCost Decimal? @db.Decimal(10, 2)
  // Physical delivery status of the shipment: preparing | in_transit | arrived.
  status       String   @default("preparing")
  createdAt    DateTime @default(now())

  collection Collection        @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  contact    Contact?          @relation("PurchaseSupplier", fields: [contactId], references: [id], onDelete: Restrict)
  platform   Contact?          @relation("PurchasePlatform", fields: [platformId], references: [id], onDelete: Restrict)
  lots       PurchaseLot[]
  expenses   PurchaseExpense[]

  @@index([collectionId])
  @@index([contactId])
  @@index([platformId])
  @@map("purchase")
}

// Inventory line of a purchase (ADR-0009 §1): a priced lot that resolves into one or
// more `Item`s over time. Intake lifecycle `status`: open | closed. Cascade-deleted
// with its purchase.
model PurchaseLot {
  id         String @id @default(cuid())
  purchaseId String
  // Optional free-text title identifying the lot (e.g. "Album Polska 1950s", "Box lot").
  // When blank, the UI derives a display label from the copies identified into the lot,
  // falling back to a positional "Lot N" (#121).
  title      String?
  // Line price in the purchase's transaction currency.
  price      Decimal @db.Decimal(10, 2)
  // Intake status: open (items still being identified, cost pending) | closed
  // (pool allocated to items, cost-basis frozen). See ADR-0009 §3/§5.
  status     String  @default("open")

  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  items    Item[]

  @@index([purchaseId])
  @@map("purchase_lot")
}

// Non-inventory line of a purchase (ADR-0009 §1), e.g. a magnifier bought alongside
// the stamps: a label and a price, with no lifecycle and no items. It absorbs its
// fair share of the shared cost so it does not inflate the stamps. Separate table
// from `PurchaseLot` on purpose (ADR-0009 §1). Cascade-deleted with its purchase.
model PurchaseExpense {
  id         String  @id @default(cuid())
  purchaseId String
  label      String
  // Line price in the purchase's transaction currency.
  price      Decimal @db.Decimal(10, 2)

  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  @@index([purchaseId])
  @@map("purchase_expense")
}

// A listing on one platform (ADR-0013, supersedes ADR-0012 §1–§2). The offer **owns its
// composition** directly (mirroring `Purchase ⊃ PurchaseLot ⊃ Item`): it holds N `OfferSet`s,
// each an atomic sellable unit. `platformId` is a `Contact` carrying the `platform` role. Price +
// currency are per-offer (platforms price independently). Lifecycle `state`: preparing | ready |
// active | paused | sold | withdrawn — a new offer starts `preparing` (composed but not yet
// published), is marked `ready` once assembled, then activated by hand (#188, #246). Nothing is
// shared between offers — the same copy listed elsewhere is a
// separate offer with its own sets. The derived "needs action" overlay (an active offer holding a
// set whose copy has already sold) is computed, never stored.
model Offer {
  id           String   @id @default(cuid())
  collectionId String
  platformId   String
  // Listing URL on the platform.
  url          String?
  // Asking price in `currency` (the offer's own transaction currency).
  price        Decimal  @db.Decimal(10, 2)
  currency     String
  state        String   @default("preparing")
  // The date the listing went live on the platform (#257), captured at offer creation and remembered
  // across creations. Distinct from `createdAt` (when the record was made); null when not recorded.
  listingDate  DateTime? @db.Date
  createdAt    DateTime @default(now())

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  platform   Contact    @relation("OfferPlatform", fields: [platformId], references: [id], onDelete: Restrict)
  sets       OfferSet[]
  saleLines  SaleLine[]

  @@index([collectionId])
  @@index([platformId])
  @@map("offer")
}

// One atomic sellable unit inside an offer (ADR-0013). A set holds one or more `Item`s that sell
// **together and indivisibly** — a series / *komplet* never breaks apart. There is no unit/quantity
// discriminator: a single-stamp offer is one 1-item set, a series is one N-item set, and a
// "quantity" listing is simply many sets. Cascade-deleted with its offer.
model OfferSet {
  id      String  @id @default(cuid())
  offerId String
  // Optional free-text label; the UI derives one from the copies when blank.
  title   String?

  offer     Offer          @relation(fields: [offerId], references: [id], onDelete: Cascade)
  items     OfferSetItem[]
  saleLines SaleLine[]

  @@index([offerId])
  @@map("offer_set")
}

// The physical copies in an offer set (ADR-0013). **N:M** — unlike `PurchaseLot`, which owns its
// items, a copy can belong to sets across several offers at once (listed on multiple platforms).
// This is the cross-platform thread: selling a copy retires it globally (`sale_line_item.itemId`
// UNIQUE) and every other offer whose set still holds it surfaces as needing action. Cascade-
// deleted with either side.
model OfferSetItem {
  offerSetId String
  itemId     String

  offerSet OfferSet @relation(fields: [offerSetId], references: [id], onDelete: Cascade)
  item     Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@id([offerSetId, itemId])
  @@index([itemId])
  @@map("offer_set_item")
}

// A sale transaction (ADR-0012). Single platform, single currency. Shared amounts —
// buyer-paid handling (+), my actual shipping (−), platform commission (−, entered manually) —
// are allocated proportionally to line sale prices by the pure engine (#163). `fxRateToBase`
// is frozen at `soldAt` (#20). A single sale can span multiple offers within the one platform.
model Sale {
  id            String   @id @default(cuid())
  collectionId  String
  platformId    String
  // Optional buyer — the `Contact` (carrying the `buyer` role) the sale went to. `onDelete:
  // Restrict`: a referenced buyer cannot be deleted without first detaching it (like the
  // purchase supplier). Null when the buyer is unknown/anonymous.
  buyerId       String?
  // The moment of sale; the FX rate is frozen as of this date.
  soldAt        DateTime @db.Date
  // Single transaction currency for every amount on this sale and its lines.
  currency      String
  // The transaction / order number in the external system (e.g. a Delcampe or Allegro order id),
  // free-text. Null when not recorded. Handy for reconciling against the marketplace.
  externalRef   String?
  // Base-currency FX rate frozen at `soldAt` (DECIMAL(65,30), like `ExchangeRate.rate`);
  // null when base == transaction currency or no rate is known yet.
  fxRateToBase  Decimal?
  // Buyer-paid handling/postage collected from the buyer (adds to proceeds, +). The buyer-side
  // proceeds have exactly one anchor (#205): either this handling is stored directly, or the total
  // the buyer paid is stored in `buyerPaidTotal` and handling is derived (total − gross). At most
  // one of the two is non-null.
  buyerHandling Decimal? @db.Decimal(10, 2)
  // The full amount the buyer paid, when that is the anchor (#205). When set, buyer handling is
  // derived = this − gross (sum of line prices) and recomputed as sold sets change, so `buyerHandling`
  // is null. Null when handling is entered directly.
  buyerPaidTotal Decimal? @db.Decimal(10, 2)
  // My actual shipping/postage cost, in `shippingCurrency` (subtracts from proceeds, −). Entered in
  // any currency (#206) — converted straight to the base currency for profit, not to the sale's
  // transaction currency.
  shippingCost  Decimal? @db.Decimal(10, 2)
  // Currency `shippingCost` was paid in (#206), independent of the sale's transaction currency.
  // Null when no shipping cost is recorded; defaults to the sale currency in the UI.
  shippingCurrency String?
  // Base-currency FX rate for `shippingCurrency`, frozen at `soldAt` (DECIMAL(65,30), like
  // `fxRateToBase`). Null when `shippingCurrency == base` (identity) or no rate is known (#206).
  shippingFxRateToBase Decimal?
  // Platform commission/fees, entered manually per transaction (subtracts, −).
  commission    Decimal? @db.Decimal(10, 2)
  // Fulfillment status in lifecycle order (#191): ordered → paid → packed → sent → received.
  // Defaults `ordered` — a freshly recorded sale is placed but not yet paid/shipped. Each change
  // also appends a `SaleStatusEvent` so the transition timeline is preserved for reporting/audit.
  status        String   @default("ordered")
  createdAt     DateTime @default(now())

  collection    Collection        @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  platform      Contact           @relation("SalePlatform", fields: [platformId], references: [id], onDelete: Restrict)
  buyer         Contact?          @relation("SaleBuyer", fields: [buyerId], references: [id], onDelete: Restrict)
  lines         SaleLine[]
  statusEvents  SaleStatusEvent[]

  @@index([collectionId])
  @@index([platformId])
  @@index([buyerId])
  @@map("sale")
}

// Append-only fulfillment-status transition log for a sale (#191). One row per status change,
// stamped at the moment of transition, so the sale's progression through ordered → paid → packed
// → sent → received is preserved for future reporting/audit. Cascades with its sale.
model SaleStatusEvent {
  id        String   @id @default(cuid())
  saleId    String
  // The status the sale moved to at `changedAt` (same token set as `Sale.status`).
  status    String
  changedAt DateTime @default(now())

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@map("sale_status_event")
}

// One line of a sale (ADR-0013): the offer set that went, the offer it sold through, its line
// sale price (sale currency), and the exact physical `Item`s that left (via `sale_line_item`).
// One line per set sold — a quantity offer selling K units records K lines.
model SaleLine {
  id         String  @id @default(cuid())
  saleId     String
  // The offer the sale came through; `SetNull` so a historical sale survives offer cleanup.
  offerId    String?
  // The offer set sold; `Restrict` so a sold set cannot be deleted out from under the sale record.
  offerSetId String
  // Line sale price in the sale's transaction currency.
  price      Decimal @db.Decimal(10, 2)

  sale     Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  offer    Offer?   @relation(fields: [offerId], references: [id], onDelete: SetNull)
  offerSet OfferSet @relation(fields: [offerSetId], references: [id], onDelete: Restrict)
  items    SaleLineItem[]

  @@index([saleId])
  @@index([offerId])
  @@index([offerSetId])
  @@map("sale_line")
}

// The specific physical copies that left on a sale line (ADR-0012). The **no-double-sale**
// invariant is a DB-level `@@unique([itemId])`: a copy can appear on at most one sale line
// ever. `onDelete: Restrict` on the item so a sold copy cannot be deleted while the sale
// record references it; the join cascades with its sale line.
model SaleLineItem {
  saleLineId String
  itemId     String
  // Whether this individual physical copy has been packed (#192). Independent of the sale's overall
  // fulfillment status (#191): packing happens per copy, and a sale can span many copies packed at
  // different times. When every copy of a sale is packed the UI hints that the sale can advance to
  // the `packed` status, but never changes `Sale.status` automatically.
  packed     Boolean  @default(false)

  saleLine SaleLine @relation(fields: [saleLineId], references: [id], onDelete: Cascade)
  item     Item     @relation(fields: [itemId], references: [id], onDelete: Restrict)

  @@id([saleLineId, itemId])
  @@unique([itemId])
  @@map("sale_line_item")
}

model Contact {
  id               String   @id @default(cuid())
  collectionId     String
  name             String
  notes            String?
  email            String?
  phone            String?
  // Roles are independent, combinable boolean flags (a contact can be several at
  // once), mirroring the disposition flags on `Item` (ADR-0007 §4, ADR-0008).
  buyer            Boolean  @default(false)
  seller           Boolean  @default(false)
  exchangePartner  Boolean  @default(false)
  auctionHouse     Boolean  @default(false)
  platform         Boolean  @default(false)
  other            Boolean  @default(false)
  // Fixed transaction currency for a platform (#196). Every offer and sale routed to this
  // platform inherits and locks this currency, guaranteeing offer↔sale consistency. Nullable —
  // only platforms carry it, and it is required (domain-enforced, not a DB constraint) before the
  // first offer/sale on the platform. A per-offer/-sale `currency` snapshot preserves history, so
  // changing this later leaves existing offers/sales untouched.
  platformCurrency String?
  createdAt        DateTime @default(now())

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  // Purchases sourced from this contact (supplier). `onDelete: Restrict` on the FK
  // (from `Purchase`) means a referenced contact cannot be deleted without first
  // detaching it (ADR-0008 §4, ADR-0009 — supersedes the old `Item` acquisition link).
  purchases         Purchase[] @relation("PurchaseSupplier")
  // Purchases routed through this contact as their platform (e.g. Allegro). Same
  // `onDelete: Restrict` guard from the `Purchase.platformId` FK.
  platformPurchases Purchase[] @relation("PurchasePlatform")
  // Sales module (ADR-0012): offers listed on this contact's platform, and sales
  // transacted through it. Both FKs are `onDelete: Restrict` (same detach-before-delete
  // guard as purchases).
  offers            Offer[]    @relation("OfferPlatform")
  salesPlatform     Sale[]     @relation("SalePlatform")
  // Sales made to this contact as the buyer (ADR-0012, #166). Same detach-before-delete guard
  // via the `Sale.buyerId` FK (`onDelete: Restrict`).
  salesBuyer        Sale[]     @relation("SaleBuyer")

  // `name` is unique per collection (see migration).
  @@unique([collectionId, name])
  @@index([collectionId])
  @@map("contact")
}

model Location {
  id           String   @id @default(cuid())
  collectionId String
  name         String
  parentId     String?
  description  String?
  // Grouping-only nodes (e.g. a cabinet) have `assignable = false`; leaf storage
  // that can hold copies (e.g. a stockbook) has `assignable = true`. Defaults true (#56).
  assignable   Boolean  @default(true)
  createdAt    DateTime @default(now())

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  // Adjacency-list hierarchy (same pattern as `CollectionArea`). Deleting a location
  // with children or items is blocked in the domain layer; the FK is SetNull as a
  // backstop, matching `CollectionArea`.
  parent     Location?  @relation("LocationChildren", fields: [parentId], references: [id])
  children   Location[] @relation("LocationChildren")
  items      Item[]

  @@index([collectionId])
  @@map("location")
}

model CollectionAreaCatalog {
  collectionAreaId String
  catalogNameId    String

  collectionArea CollectionArea @relation(fields: [collectionAreaId], references: [id], onDelete: Cascade)
  catalogName    CatalogName    @relation(fields: [catalogNameId], references: [id], onDelete: Cascade)

  @@id([collectionAreaId, catalogNameId])
  @@map("collection_area_catalog")
}

model CollectionAreaVendor {
  collectionAreaId String
  catalogVendorId  String
  areaPrefix       String?

  collectionArea CollectionArea @relation(fields: [collectionAreaId], references: [id], onDelete: Cascade)
  catalogVendor  CatalogVendor  @relation(fields: [catalogVendorId], references: [id], onDelete: Cascade)

  @@id([collectionAreaId, catalogVendorId])
  @@map("collection_area_vendor")
}

model Issue {
  id               String   @id @default(cuid())
  collectionId     String
  collectionAreaId String
  name             String?
  year             Int?
  isAutoCreated    Boolean  @default(false)
  createdAt        DateTime @default(now())

  collection     Collection          @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  collectionArea CollectionArea       @relation(fields: [collectionAreaId], references: [id], onDelete: Cascade)
  members        IssueMember[]
  catalogNumbers IssueCatalogNumber[]

  @@map("issue")
}

model IssueCatalogNumber {
  issueId         String
  catalogVendorId String
  firstNumber     String
  lastNumber      String?

  issue         Issue         @relation(fields: [issueId], references: [id], onDelete: Cascade)
  catalogVendor CatalogVendor @relation(fields: [catalogVendorId], references: [id], onDelete: Cascade)

  @@id([issueId, catalogVendorId])
  @@map("issue_catalog_number")
}

model IssueMember {
  issueId                 String
  stampId                 String
  requiredForCompleteness Boolean @default(false)

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  stamp Stamp @relation("IssueMemberStamp", fields: [stampId], references: [id], onDelete: Cascade)

  @@id([issueId, stampId])
  @@map("issue_member")
}

model ExchangeRate {
  id           String   @id @default(cuid())
  collectionId String
  fromCurrency String
  toCurrency   String
  rate         Decimal
  fetchedAt    DateTime

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@unique([collectionId, fromCurrency, toCurrency])
  @@map("exchange_rate")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}
