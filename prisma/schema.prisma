generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String       @id
  name          String
  email         String       @unique
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime
  sessions      Session[]
  accounts      Account[]
  collections   Collection[]

  @@map("user")
}

model Collection {
  id        String   @id @default(cuid())
  slug      String
  name      String
  ownerId   String
  createdAt DateTime @default(now())

  owner           User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  collectionAreas CollectionArea[]
  catalogVendors  CatalogVendor[]
  stamps          Stamp[]
  issues          Issue[]

  @@unique([ownerId, slug])
  @@map("collection")
}

model CatalogVendor {
  id           String @id @default(cuid())
  collectionId String
  name         String
  abbreviation String

  collection            Collection             @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  catalogNames          CatalogName[]
  stampCatalogNumbers   StampCatalogNumber[]
  collectionAreaVendors CollectionAreaVendor[]

  @@map("catalog_vendor")
}

model CatalogName {
  id           String  @id @default(cuid())
  vendorId     String
  name         String
  currency     String
  abbreviation String?

  vendor                 CatalogVendor          @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  catalogEditions        CatalogEdition[]
  collectionAreaCatalogs CollectionAreaCatalog[]
  primaryForAreas        CollectionArea[]        @relation("CollectionAreaPrimaryCatalog")
  issues                 Issue[]

  @@map("catalog_name")
}

model CatalogEdition {
  id            String @id @default(cuid())
  catalogNameId String
  year          Int

  catalogName CatalogName @relation(fields: [catalogNameId], references: [id], onDelete: Cascade)

  @@map("catalog_edition")
}

model CollectionArea {
  id                   String   @id @default(cuid())
  collectionId         String
  name                 String
  parentId             String?
  description          String?
  catalogId            String?
  primaryCatalogNameId String?
  createdAt            DateTime @default(now())

  collection             Collection             @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  parent                 CollectionArea?        @relation("CollectionAreaChildren", fields: [parentId], references: [id])
  children               CollectionArea[]       @relation("CollectionAreaChildren")
  stampAreaLinks         StampCollectionArea[]
  primaryCatalogName     CatalogName?           @relation("CollectionAreaPrimaryCatalog", fields: [primaryCatalogNameId], references: [id])
  collectionAreaCatalogs CollectionAreaCatalog[]
  collectionAreaVendors  CollectionAreaVendor[]

  @@map("collection_area")
}

model StampCollectionArea {
  stampId          String
  collectionAreaId String
  isPrimary        Boolean @default(false)

  stamp          Stamp          @relation(fields: [stampId], references: [id], onDelete: Cascade)
  collectionArea CollectionArea @relation(fields: [collectionAreaId], references: [id], onDelete: Cascade)

  @@id([stampId, collectionAreaId])
  @@map("stamp_collection_area")
}

model Stamp {
  id           String   @id @default(cuid())
  collectionId String
  parentId     String?
  name         String?
  issuedYear   Int?
  createdAt    DateTime @default(now())

  collection        Collection            @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  parent            Stamp?                @relation("StampVariants", fields: [parentId], references: [id])
  variants          Stamp[]               @relation("StampVariants")
  stampAreaLinks    StampCollectionArea[]
  catalogNumbers    StampCatalogNumber[]
  issueMemberships  IssueMember[]         @relation("IssueMemberStamp")

  @@map("stamp")
}

model StampCatalogNumber {
  stampId         String
  catalogVendorId String
  number          String

  stamp         Stamp         @relation(fields: [stampId], references: [id], onDelete: Cascade)
  catalogVendor CatalogVendor @relation(fields: [catalogVendorId], references: [id], onDelete: Cascade)

  @@id([stampId, catalogVendorId])
  @@map("stamp_catalog_number")
}

model CollectionAreaCatalog {
  collectionAreaId String
  catalogNameId    String

  collectionArea CollectionArea @relation(fields: [collectionAreaId], references: [id], onDelete: Cascade)
  catalogName    CatalogName    @relation(fields: [catalogNameId], references: [id], onDelete: Cascade)

  @@id([collectionAreaId, catalogNameId])
  @@map("collection_area_catalog")
}

model CollectionAreaVendor {
  collectionAreaId String
  catalogVendorId  String
  areaPrefix       String?

  collectionArea CollectionArea @relation(fields: [collectionAreaId], references: [id], onDelete: Cascade)
  catalogVendor  CatalogVendor  @relation(fields: [catalogVendorId], references: [id], onDelete: Cascade)

  @@id([collectionAreaId, catalogVendorId])
  @@map("collection_area_vendor")
}

model Issue {
  id            String   @id @default(cuid())
  collectionId  String
  catalogNameId String
  name          String?
  isAutoCreated Boolean  @default(false)
  createdAt     DateTime @default(now())

  collection  Collection    @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  catalogName CatalogName   @relation(fields: [catalogNameId], references: [id], onDelete: Cascade)
  members     IssueMember[]

  @@map("issue")
}

model IssueMember {
  issueId                 String
  stampId                 String
  requiredForCompleteness Boolean @default(false)

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  stamp Stamp @relation("IssueMemberStamp", fields: [stampId], references: [id], onDelete: Cascade)

  @@id([issueId, stampId])
  @@map("issue_member")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}
